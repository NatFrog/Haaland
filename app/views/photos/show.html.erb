<% content_for :title, "#{@photo.caption} — Haaland Hub" %>

<section class="section">
  <div class="container container-narrow">
    <div class="photo-show">
      <% if @photo.image.attached? %>
        <%= image_tag @photo.image.variant(resize_to_limit: [1200, 1200]), alt: @photo.caption, class: "photo-show-image" %>
      <% end %>

      <div class="photo-show-body">
        <h1><%= @photo.caption %></h1>
        <p class="meta">Shared by <%= @photo.author_name %> · <%= time_ago(@photo.created_at) %></p>

        <div class="action-row">
          <%= link_to "Edit", edit_photo_path(@photo), class: "btn btn-secondary btn-sm" %>
          <%= button_to "Delete", @photo, method: :delete, class: "btn btn-danger btn-sm", data: { turbo_confirm: "Remove this photo?" } %>
          <%= link_to "Back to Gallery", photos_path, class: "text-link" %>
        </div>
      </div>
    </div>
  </div>
</section>
